// VD Manager - Audiovisual Description Team Management System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(MEMBER)
  jobRole   JobRole  @default(REDACTEUR)
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  projectsAsRedacteur Project[]      @relation("Redacteur")
  projectsAsTechSon   Project[]      @relation("TechSon")
  projectsAsNarrator  Project[]      @relation("Narrator")
  announcements       Announcement[]
  attendances         Attendance[]
}

enum UserRole {
  ADMIN
  MEMBER
}

enum JobRole {
  REDACTEUR
  NARRATEUR
  TECH_SON
  LIVREUR
}

// ─────────────────────────────────────────────
// PROJECTS
// ─────────────────────────────────────────────

model Project {
  id            String        @id @default(cuid())
  name          String
  seriesName    String
  season        String
  episodeNumber String?
  materialRef   String?

  workflowStep  WorkflowStep  @default(REDACTION)
  status        ProjectStatus @default(NOT_STARTED)

  pageCount     Int?
  writingDate   DateTime?
  durationMin   Float?

  mixingDate    DateTime?
  narratorName  String?
  isAINarrator  Boolean       @default(false)

  deadline      DateTime
  comment       String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  redacteurId   String?
  redacteur     User?         @relation("Redacteur", fields: [redacteurId], references: [id])

  techSonId     String?
  techSon       User?         @relation("TechSon", fields: [techSonId], references: [id])

  narratorId    String?
  narrator      User?         @relation("Narrator", fields: [narratorId], references: [id])
}

enum WorkflowStep {
  REDACTION
  NARRATION
  MIXAGE
  LIVRAISON
  TERMINE
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE
  CANCELLED
}

// ─────────────────────────────────────────────
// ATTENDANCE (Pointage)
// ─────────────────────────────────────────────

model Attendance {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  status      AttendanceStatus
  startedAt   DateTime         @default(now())
  endedAt     DateTime?
  durationMin Float?
  note        String?

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
  @@index([startedAt])
}

enum AttendanceStatus {
  EN_PRODUCTION
  PAUSE
  REUNION
  FORMATION
  FIN_DE_SHIFT
  ABSENT
}

// ─────────────────────────────────────────────
// ANNOUNCEMENTS
// ─────────────────────────────────────────────

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
}

// ─────────────────────────────────────────────
// CHARACTERS DATABASE
// ─────────────────────────────────────────────

model Series {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seasons     Season[]
}

model Season {
  id        String      @id @default(cuid())
  number    Int
  year      Int?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  seriesId   String
  series     Series      @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  characters Character[]

  @@unique([seriesId, number])
}

model Character {
  id        String   @id @default(cuid())
  name      String
  actorName String
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seasonId  String
  season    Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
}
